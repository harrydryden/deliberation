NODE_ENV=development
PORT=3000
HOST=0.0.0.0

# Database
DATABASE_URL=postgresql://postgres:password@localhost:5432/deliberation

# Redis
REDIS_URL=redis://localhost:6379

# JWT - CRITICAL: Use a strong, randomly generated secret in production (minimum 256 bits)
# Generate with: openssl rand -hex 32
JWT_SECRET=CHANGE_THIS_TO_A_CRYPTOGRAPHICALLY_SECURE_RANDOM_256_BIT_SECRET_IN_PRODUCTION

# AI Services
OPENAI_API_KEY=your-openai-api-key

# Rate Limiting
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW=60000

# Token Bucket
TOKEN_BUCKET_CAPACITY=100
TOKEN_BUCKET_REFILL_RATE=10
TOKEN_BUCKET_REFILL_INTERVAL=1000

# CORS
CORS_ORIGIN=http://localhost:5173,http://localhost:3000
CORS_CREDENTIALS=true

# Logging
LOG_LEVEL=info

# SSE
SSE_HEARTBEAT_INTERVAL=30000
SSE_MAX_CONNECTIONS=1000